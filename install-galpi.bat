@echo off
chcp 65001 >nul 2>nul
if not exist "C:\Program Files\Git\bin\bash.exe" (
    echo [ERROR] Git Bash not found.
    pause
    goto :eof
)
set "ALJALDDAG_BAT=%~f0"
set "ALJALDDAG_DIR=%CD%"
set "B=%TEMP%\galpi_boot.sh"
> "%B%" echo #!/bin/bash
>> "%B%" echo SRC="$(cygpath "$ALJALDDAG_BAT")"
>> "%B%" echo TGT="$(cygpath "$ALJALDDAG_DIR")"
>> "%B%" echo L=$(awk '/^__ARCHIVE__$/{print NR+1;exit}' "$SRC")
>> "%B%" echo T=$(mktemp -d)
>> "%B%" echo trap "rm -rf $T" EXIT
>> "%B%" echo tail -n +$L "$SRC" ^| base64 -d ^| tar xzf - -C "$T"
>> "%B%" echo cd "$TGT"
>> "%B%" echo bash "$T/.claude/scripts/_install.sh" "$T" "$TGT"
"C:\Program Files\Git\bin\bash.exe" "%B%"
del "%B%" >nul 2>nul
pause
goto :eof
